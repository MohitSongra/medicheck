# ============================================================
# MediCheck — .gitignore (Production-Grade)
# ============================================================

# --------------- Python bytecode / cache --------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo

# --------------- Virtual environments ----------------------
venv/
.venv/
env/
ENV/
.env/

# --------------- Environment variables ---------------------
.env
.env.local
.env.*.local

# --------------- IDE / Editor ------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace
.spyderproject
.spyproject

# --------------- OS generated files ------------------------
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# --------------- Testing / Linting -------------------------
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
*.py,cover
.hypothesis/

# --------------- Distribution / Packaging ------------------
*.egg-info/
*.egg
dist/
build/
sdist/
wheels/
*.whl
pip-wheel-metadata/
*.manifest
*.spec
MANIFEST

# --------------- Jupyter -----------------------------------
.ipynb_checkpoints/

# --------------- Kaggle raw data (large; re-downloadable) --
data/kaggle_raw/

# --------------- Model artifacts (re-trainable) ------------
# Trained model artifact (regenerate via `python -m model.train`)
model/bayesian_model.pkl

# --------------- Logs & temp files -------------------------
*.log
*.tmp
*.bak
*.swp
*.pid
*.seed
*.pid.lock

# --------------- Docker ------------------------------------
*.env.docker
docker-compose.override.yml

# --------------- Misc -------------------------------------
*.DS_Store
*.pem
*.key
