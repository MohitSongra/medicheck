# ===========================================================
# MediCheck — Environment Variables
# Copy this file to .env and fill in real values
# NEVER commit .env to version control
# ===========================================================

# ── App Config ──
APP_ENV=production
APP_PORT=8000
STREAMLIT_PORT=8501
DEBUG=False

# ── API Config ──
API_HOST=0.0.0.0
API_BASE_URL=http://localhost:8000

# ── Model Config ──
MODEL_PATH=model/bayesian_model.pkl
DATA_PATH=data/disease_info.json

# ── Security ──
SECRET_KEY=your-secret-key-here
ALLOWED_ORIGINS=http://localhost:8501

# ── Logging ──
LOG_LEVEL=INFO
